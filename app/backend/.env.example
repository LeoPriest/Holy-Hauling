# Required for screenshot/image extraction (Slice 3)
# Get your API key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# The Claude model to use for image extraction — set to any vision-capable model name
OCR_MODEL=your_model_name_here

# Auth (Slice auth-roles)
JWT_SECRET=<random 32+ character string>
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=30

# Web Push (optional — push notifications disabled if VAPID_PRIVATE_KEY is unset)
VAPID_PRIVATE_KEY=<generated with pywebpush keygen>
VAPID_PUBLIC_KEY=<generated with pywebpush keygen>
VAPID_CLAIM_EMAIL=mailto:admin@holyhauling.com

# Twilio SMS alerts
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Email — Resend (preferred) or SMTP fallback
# Sign up at resend.com, verify your domain, grab the API key
RESEND_API_KEY=
RESEND_FROM=Holy Hauling <notifications@holyhauling.com>
# SMTP fallback (used if RESEND_API_KEY is not set)
SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Calendar OAuth (admin setup via /admin/google/connect)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/admin/google/callback

# Square Payments
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_LOCATION_ID=
SQUARE_WEBHOOK_SIGNATURE_KEY=
# Public URL of this backend — used in Square webhook config and SMS links
SQUARE_NOTIFICATION_URL=https://<your-railway-domain>/square/webhook

# Railway / Production overrides
# DATABASE_URL=sqlite+aiosqlite:////data/holy_hauling.db
# UPLOADS_DIR=/data/uploads
